{
  "name": "darpan-ui",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "Darpan frontend app (Vue + TypeScript + Vite)",
  "scripts": {
    "dev": "vite",
    "dev:stack": "./scripts/dev-stack.sh",
    "build": "npm run type-check && npm run build-only",
    "build-only": "vite build",
    "build:firebase": "vite build --mode firebase",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .ts,.vue --max-warnings=0",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "npm run lint && npm run type-check && npm run test"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0",
    "vue-eslint-parser": "^9.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
